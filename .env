PORT=5000
JWT_SECRET=super-secret-key-for-disaster-platform

# ─── Fast2SMS Configuration ────────────────────────────────────────────────────
# Get a free API key at: https://www.fast2sms.com
# Leave as placeholder to run in DEMO mode (logs to console, no real SMS)
FAST2SMS_API_KEY=your_fast2sms_api_key

# ─── SMS Mode ──────────────────────────────────────────────────────────────────
# Set to "fast2sms" to send real SMS, or "demo" to only log to console
SMS_MODE=demo

# ─── Authority Alert Phone Numbers ────────────────────────────────────────────
# 10-digit Indian mobile numbers — system adds +91 automatically
NDRF_ALERT_PHONE=9876543210
FIRE_ALERT_PHONE=9876543211
